---
const year = new Date().getFullYear();
---

<footer class="bg-[#111111] text-white">
  <!-- CTA Band -->
  <div class="bg-red-600 py-16 px-6 lg:px-10 text-center">
    <h2 class="text-4xl lg:text-5xl font-black text-white mb-3">Starting a New Project?</h2>
    <p class="text-white/80 text-lg mb-8">Let's connect and build something exceptional together.</p>
    <a
      href="/contact"
      class="rd-footer-cta inline-flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-red-600 font-bold px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200"
    >
      Contact Us Today
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>

  <!-- Main Footer -->
  <div class="px-6 lg:px-10 py-16">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand column -->
      <div>
        <a href="/" class="flex flex-col leading-none mb-6 w-fit" aria-label="Reynolds Dryline Home">
          <span class="text-white font-black text-2xl tracking-tight">Reynolds</span>
          <span class="text-white font-light text-sm tracking-[0.3em] uppercase border border-white/40 px-1 -mt-0.5">Dryline</span>
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-6">
          Total building finishes solutions for projects throughout the UK. Expert management, enthusiastic teams, and a heritage of excellence since 1963.
        </p>
        <div class="flex items-center gap-3">
          <a
            href="https://www.linkedin.com/company/reynolds-dryline"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-white/10 hover:bg-red-600 flex items-center justify-center transition-colors duration-200"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/reynoldsdryline"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-white/10 hover:bg-red-600 flex items-center justify-center transition-colors duration-200"
            aria-label="Instagram"
          >
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-4">Quick Links</h3>
        <div class="w-10 h-0.5 bg-red-600 mb-5"></div>
        <ul class="space-y-3">
          {[
            { href: '/about', label: 'About Reynolds' },
            { href: '/services', label: 'Our Services' },
            { href: '/projects', label: 'Project Portfolio' },
            { href: '/news', label: 'Latest News' },
            { href: '/careers', label: 'Careers' },
          ].map(link => (
            <li>
              <a href={link.href} class="rd-link-underline text-white/60 hover:text-white text-sm transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-4">Services</h3>
        <div class="w-10 h-0.5 bg-red-600 mb-5"></div>
        <ul class="space-y-3">
          {[
            { href: '/services/metal-stud-partitioning', label: 'Metal Stud Partitioning' },
            { href: '/services/suspended-ceilings', label: 'Suspended Ceilings' },
            { href: '/services/structural-framing-systems', label: 'Structural Framing Systems' },
            { href: '/services/insulation-sound-proofing', label: 'Insulation & Sound Proofing' },
            { href: '/services/professional-plastering', label: 'Professional Plastering' },
          ].map(link => (
            <li>
              <a href={link.href} class="rd-link-underline text-white/60 hover:text-white text-sm transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-4">Contact Info</h3>
        <div class="w-10 h-0.5 bg-red-600 mb-5"></div>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <address class="text-white/60 text-sm not-italic leading-relaxed">
              9 Quorn Business Quarter,<br />
              Loughborough Road,<br />
              Leicestershire, LE12 7XF
            </address>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            <a href="tel:01509816600" class="rd-link-underline text-white/60 hover:text-white text-sm transition-colors duration-200">
              01509 816 600
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            <a href="mailto:info@reynoldsltd.co.uk" class="rd-link-underline text-white/60 hover:text-white text-sm transition-colors duration-200">
              info@reynoldsltd.co.uk
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10 px-6 lg:px-10 py-5">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/40 text-xs">
        &copy; {year} L Reynolds (Building Systems) Ltd. All Rights Reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="/terms" class="rd-link-underline text-white/40 hover:text-white/70 text-xs transition-colors duration-200">Terms &amp; Conditions</a>
        <a href="/privacy" class="rd-link-underline text-white/40 hover:text-white/70 text-xs transition-colors duration-200">Privacy Policy</a>
        <a href="/cookies" class="rd-link-underline text-white/40 hover:text-white/70 text-xs transition-colors duration-200">Cookies</a>
      </div>
    </div>
  </div>
</footer>
