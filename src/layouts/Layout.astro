---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, noindex = false } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, 'https://www.reynoldsdryline.co.uk').toString();
const ogImageURL = ogImage || 'https://www.reynoldsdryline.co.uk/og-image.jpg';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow, noarchive" />}
    {noindex && <meta name="googlebot" content="noindex, nofollow, noarchive" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&display=swap" rel="stylesheet" />
    <!-- Netlify Identity — required for Decap CMS /admin login redirect -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageURL} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Reynolds Dryline",
      "description": "Leaders in specialist building finishes. Providing complete dryline solutions since 1963.",
      "url": "https://www.reynoldsdryline.co.uk",
      "telephone": "01509816600",
      "email": "info@reynoldsltd.co.uk",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "9 Quorn Business Quarter, Loughborough Road",
        "addressLocality": "Mountsorrel",
        "addressRegion": "Leicestershire",
        "postalCode": "LE12 7XF",
        "addressCountry": "GB"
      },
      "foundingDate": "1963",
      "areaServed": "United Kingdom"
    }
    </script>
    <!-- Optional per-page head content -->
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased" style="font-family: 'Montserrat', system-ui, sans-serif;">
    <slot />
    <!-- Netlify Identity redirect handler -->
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', function(user) {
          if (!user) {
            window.netlifyIdentity.on('login', function() {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
    <!-- Scroll animations -->
    <script is:inline>
      (function () {
        document.body.classList.add('js-ready');
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var el = entry.target;
              var delay = parseInt(el.getAttribute('data-delay') || '0', 10);
              setTimeout(function () {
                el.classList.add('animate-in');
              }, delay);
              observer.unobserve(el);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
        function initObservers() {
          document.querySelectorAll('[data-animate]').forEach(function (el) {
            observer.observe(el);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initObservers);
        } else {
          initObservers();
        }
      })();
    </script>
  </body>
</html>
