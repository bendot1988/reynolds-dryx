---
import ReynoldsLayout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';

const roles = [
  {
    title: 'Drylining Operative',
    type: 'Full Time',
    location: 'Various UK Sites',
    desc: 'Experienced drylining operatives required for ongoing and upcoming projects across the UK. CSCS card essential.',
  },
  {
    title: 'Site Supervisor',
    type: 'Full Time',
    location: 'Various UK Sites',
    desc: 'We are looking for experienced site supervisors to manage our operatives and ensure quality delivery on site.',
  },
  {
    title: 'Estimator',
    type: 'Full Time',
    location: 'Leicestershire (Office Based)',
    desc: 'An experienced estimator is required to join our growing commercial team. Experience in drylining and building finishes is essential.',
  },
  {
    title: 'Contracts Manager',
    type: 'Full Time',
    location: 'Leicestershire / UK Wide',
    desc: 'We are seeking an experienced contracts manager to oversee multiple projects, managing programmes, budgets, and client relationships.',
  },
];
---

<ReynoldsLayout
  title="Careers at Reynolds Dryline | Join Our Team"
  description="Join the Reynolds Dryline team. We are always looking for talented drylining operatives, supervisors, estimators, and contracts managers to join our growing business."
  canonical="https://www.reynoldsdryline.co.uk/careers"
>
  <Header currentPath="/careers" />

  <PageHero
    title="Join Our Team"
    subtitle="We're always looking for talented, passionate people to join the Reynolds Dryline family. Build your career with a company that values expertise and rewards hard work."
    breadcrumb="Careers"
  />

  <!-- Why Work With Us -->
  <section class="bg-white py-20 px-6 lg:px-10">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div data-animate>
        <p class="rd-label mb-3">Why Reynolds?</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-6 leading-tight">
          A Company You Can Build a Career With
        </h2>
        <div class="space-y-4 text-gray-600 leading-relaxed">
          <p>
            Reynolds Dryline has been a trusted employer in the construction sector for over 60 years. We offer our team members the opportunity to work on some of the UK's most exciting and prestigious projects.
          </p>
          <p>
            We invest in our people through training, development, and clear career progression pathways. Whether you're an experienced operative or just starting out in the industry, we have opportunities that can help you grow.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-5 mt-8">
          {[
            { title: 'Competitive Pay', desc: 'Industry-leading rates for skilled operatives and management.' },
            { title: 'Training & Development', desc: 'Ongoing investment in your skills and qualifications.' },
            { title: 'Career Progression', desc: 'Clear pathways from operative to management.' },
            { title: 'Nationwide Projects', desc: 'Work on high-profile projects across the UK.' },
          ].map(benefit => (
            <div class="bg-gray-50 p-5">
              <h3 class="font-bold text-gray-900 text-sm mb-2">{benefit.title}</h3>
              <p class="text-gray-500 text-xs leading-relaxed">{benefit.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div data-animate data-delay="100">
        <img
          src="/assets/reynolds/project-building.jpg"
          alt="Reynolds Dryline team at work"
          class="w-full h-96 object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Current Vacancies -->
  <section class="bg-gray-50 py-20 px-6 lg:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14" data-animate>
        <p class="rd-label mb-3">Opportunities</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4">Current Vacancies</h2>
        <div class="w-12 h-1 bg-red-600 mx-auto"></div>
      </div>

      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class="bg-white p-6 lg:p-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-l-4 border-red-600" data-animate data-delay={`${i * 80}`}>
            <div>
              <h3 class="text-xl font-black text-gray-900 mb-2">{role.title}</h3>
              <div class="flex flex-wrap gap-3 mb-3">
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-gray-600 bg-gray-100 px-3 py-1">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.06 15.94 0 13.36 0c-1.3 0-2.51.52-3.36 1.36L9 2.36 7.99 1.35C7.14.52 5.93 0 4.64 0 2.06 0 0 2.06 0 4.64c0 .48.11.92.18 1.36H0v14c0 1.1.9 2 2 2h20c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/>
                  </svg>
                  {role.type}
                </span>
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-gray-600 bg-gray-100 px-3 py-1">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                  </svg>
                  {role.location}
                </span>
              </div>
              <p class="text-gray-600 text-sm leading-relaxed">{role.desc}</p>
            </div>
            <a
              href="#apply"
              class="flex-shrink-0 inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold px-6 py-3 text-xs tracking-widest uppercase transition-colors duration-200"
            >
              Apply Now
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Subcontractors -->
  <section class="bg-[#111111] py-20 px-6 lg:px-10">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div data-animate>
        <p class="text-red-500 text-xs font-bold tracking-widest uppercase mb-3">Subcontractors</p>
        <h2 class="text-4xl lg:text-5xl font-black text-white mb-6 leading-tight">
          Are You a Drylining Subcontractor?
        </h2>
        <p class="text-white/70 text-lg leading-relaxed mb-8">
          We are always looking to expand our network of trusted subcontractors. If you have experience in drylining, metal stud partitioning, suspended ceilings, or plastering — we'd love to hear from you.
        </p>
        <a href="#apply" class="rd-btn-primary">
          Register Your Interest
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-2 gap-4" data-animate data-delay="100">
        {[
          'CSCS Card Required',
          'Public Liability Insurance',
          'Relevant Experience',
          'References Available',
        ].map(req => (
          <div class="bg-white/5 border border-white/10 p-5 flex items-center gap-3">
            <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-white/80 text-sm font-medium">{req}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Application Form -->
  <section id="apply" class="bg-white py-20 px-6 lg:px-10">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12" data-animate>
        <p class="rd-label mb-3">Apply Now</p>
        <h2 class="text-4xl font-black text-gray-900 mb-4">Send Us Your Application</h2>
        <div class="w-12 h-1 bg-red-600 mx-auto"></div>
      </div>

      <form
        name="careers"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        enctype="multipart/form-data"
        class="space-y-5"
        id="rd-careers-form"
        data-animate
        data-delay="100"
      >
        <input type="hidden" name="form-name" value="careers" />
        <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="c-first-name" class="block text-xs font-bold tracking-widest uppercase text-gray-700 mb-2">First Name *</label>
            <input type="text" id="c-first-name" name="first-name" required class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-red-600 transition-colors duration-200" />
          </div>
          <div>
            <label for="c-last-name" class="block text-xs font-bold tracking-widest uppercase text-gray-700 mb-2">Last Name *</label>
            <input type="text" id="c-last-name" name="last-name" required class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-red-600 transition-colors duration-200" />
          </div>
        </div>

        <div>
          <label for="c-email" class="block text-xs font-bold tracking-widest uppercase text-gray-700 mb-2">Email Address *</label>
          <input type="email" id="c-email" name="email" required class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-red-600 transition-colors duration-200" />
        </div>

        <div>
          <label for="c-phone" class="block text-xs font-bold tracking-widest uppercase text-gray-700 mb-2">Phone Number *</label>
          <input type="tel" id="c-phone" name="phone" required class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-red-600 transition-colors duration-200" />
        </div>

        <div>
          <label for="c-position" class="block text-xs font-bold tracking-widest uppercase text-gray-700 mb-2">Position Applying For *</label>
          <select id="c-position" name="position" required class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-red-600 transition-colors duration-200 bg-white">
            <option value="">Select a position...</option>
            <option value="drylining-operative">Drylining Operative</option>
            <option value="site-supervisor">Site Supervisor</option>
            <option value="estimator">Estimator</option>
            <option value="contracts-manager">Contracts Manager</option>
            <option value="subcontractor">Subcontractor Registration</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="c-experience" class="block text-xs font-bold tracking-widest uppercase text-gray-700 mb-2">Years of Experience</label>
          <select id="c-experience" name="experience" class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-red-600 transition-colors duration-200 bg-white">
            <option value="">Select...</option>
            <option value="0-2">0–2 years</option>
            <option value="2-5">2–5 years</option>
            <option value="5-10">5–10 years</option>
            <option value="10+">10+ years</option>
          </select>
        </div>

        <div>
          <label for="c-message" class="block text-xs font-bold tracking-widest uppercase text-gray-700 mb-2">Cover Letter / Message</label>
          <textarea id="c-message" name="message" rows="5" class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-red-600 transition-colors duration-200 resize-none" placeholder="Tell us about yourself and your experience..."></textarea>
        </div>

        <div>
          <label for="c-cv" class="block text-xs font-bold tracking-widest uppercase text-gray-700 mb-2">Upload CV (PDF or Word)</label>
          <input type="file" id="c-cv" name="cv" accept=".pdf,.doc,.docx" class="w-full border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:border-red-600 transition-colors duration-200" />
        </div>

        <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-4 text-sm tracking-widest uppercase transition-colors duration-200 flex items-center justify-center gap-2">
          Submit Application
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
      </form>

      <div id="rd-careers-success" class="hidden mt-6 bg-green-50 border border-green-200 p-6 text-center">
        <svg class="w-10 h-10 text-green-500 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="text-lg font-bold text-gray-900 mb-1">Application Received!</h3>
        <p class="text-gray-600 text-sm">Thank you for your interest. We'll review your application and be in touch soon.</p>
      </div>
    </div>
  </section>

  <Footer />
</ReynoldsLayout>

<script>
  const form = document.getElementById('rd-careers-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('rd-careers-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    try {
      const response = await fetch('/', {
        method: 'POST',
        body: formData,
      });

      if (response.ok) {
        form.style.display = 'none';
        successMsg?.classList.remove('hidden');
      }
    } catch (err) {
      console.error('Form submission error:', err);
    }
  });
</script>
