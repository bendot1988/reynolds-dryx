---
import ReynoldsLayout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const yearsTrading = new Date().getFullYear() - 1963;
const partnerLogos = [
  { src: '/assets/reynolds/partner-clowes.png', alt: 'Clowes' },
  { src: '/assets/reynolds/partner-engie.png', alt: 'ENGIE' },
  { src: '/assets/reynolds/partner-winvic.png', alt: 'Winvic' },
  { src: '/assets/reynolds/partner-gallifordtry.png', alt: 'Galliford Try' },
  { src: '/assets/reynolds/partner-bowmer-kirkland.png', alt: 'Bowmer Kirkland' },
  { src: '/assets/reynolds/partner-willmott-dixon.png', alt: 'Willmott Dixon' },
];
---

<ReynoldsLayout
  title="Reynolds Dryline | Providing Complete Dryline Solutions Since 1963"
  description="Leaders in specialist building finishes. Fulfilling high-value projects to programme, budget, and unmatched quality standards. Established 1963."
  canonical="https://www.reynoldsdryline.co.uk/"
>
  <Fragment slot="head">
    <link rel="preload" href="/assets/reynolds/hero-bg.jpg" as="image" fetchpriority="high" />
    <link rel="preconnect" href="https://tanro.co.uk" crossorigin />
  </Fragment>

  <Header currentPath="/" />

  <!-- ============================================================
       HERO SECTION — Full-screen video background
  ============================================================ -->
  <section class="relative min-h-screen flex flex-col justify-center overflow-hidden">
    <!-- Video background -->
    <video
      id="rd-hero-video"
      class="absolute inset-0 w-full h-full object-cover"
      src="https://tanro.co.uk/wp-content/uploads/2024/07/TanRo-New-Offices-V1.mp4"
      poster="/assets/reynolds/hero-bg.jpg"
      preload="auto"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    ></video>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-black/65"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto w-full px-6 lg:px-10 py-32 lg:py-40">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-red-600 text-white text-xs font-bold tracking-widest uppercase px-4 py-2 mb-8 rounded-[5px]" data-animate data-delay="0">
        Since 1963
      </div>

      <!-- Headline -->
      <h1 class="text-6xl sm:text-7xl lg:text-[6.75rem] font-black text-white leading-[0.94] mb-6 max-w-3xl" data-animate data-delay="100">
        Providing Complete<br />
        <span class="text-red-500">Dryline</span> Solutions
      </h1>

      <!-- Subheading -->
      <p class="text-white/88 text-xl lg:text-2xl max-w-lg mb-10 leading-relaxed font-medium" data-animate data-delay="200">
        Leaders in specialist building finishes. Fulfilling high-value projects to programme, budget, and unmatched quality standards.
      </p>

      <!-- CTAs (.rd-hero-cta in global.css; footer band uses .rd-hero-cta--on-red) -->
      <div class="flex flex-wrap gap-4" data-animate data-delay="300">
        <a href="/contact" class="rd-hero-cta rd-btn-primary">
          Discuss Your Project
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/projects" class="rd-hero-cta rd-btn-outline">
          View Projects
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/40 animate-bounce z-10">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- ============================================================
       TRUST STRIP — PROOF ABOVE THE FOLD
  ============================================================ -->
  <section class="rd-section--surface border-y border-gray-200/80">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-7 lg:py-8">
      <div class="rd-panel rd-panel--subtle p-6 lg:p-7 grid grid-cols-1 lg:grid-cols-[1.1fr_1fr_1.4fr] gap-6 lg:gap-8 items-center">
        <div class="flex items-center gap-4" data-animate>
          <div class="w-12 h-12 rounded-[10px] bg-red-600 text-white flex items-center justify-center text-xl font-black">
            {yearsTrading}+
          </div>
          <div>
            <p class="text-[0.68rem] font-bold tracking-[0.11em] uppercase text-gray-500">Years Trading</p>
            <p class="text-sm text-gray-800 font-semibold">Delivering specialist drylining since 1963</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-2.5" data-animate data-delay="80">
          <span class="inline-flex items-center justify-center rounded-[10px] border border-gray-300 bg-gray-50 px-3 py-2 text-[0.66rem] font-bold tracking-[0.1em] uppercase text-gray-700">H&amp;S Focused</span>
          <span class="inline-flex items-center justify-center rounded-[10px] border border-gray-300 bg-gray-50 px-3 py-2 text-[0.66rem] font-bold tracking-[0.1em] uppercase text-gray-700">Compliance Led</span>
          <span class="inline-flex items-center justify-center rounded-[10px] border border-gray-300 bg-gray-50 px-3 py-2 text-[0.66rem] font-bold tracking-[0.1em] uppercase text-gray-700">Quality Assured</span>
          <span class="inline-flex items-center justify-center rounded-[10px] border border-gray-300 bg-gray-50 px-3 py-2 text-[0.66rem] font-bold tracking-[0.1em] uppercase text-gray-700">Fully Insured</span>
        </div>

        <div data-animate data-delay="140">
          <p class="text-[0.68rem] font-bold tracking-[0.11em] uppercase text-gray-500 mb-3">Trusted By Leading Contractors</p>
          <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center rounded-[8px] border border-gray-300 bg-white px-2.5 py-1.5 text-[0.62rem] font-semibold tracking-[0.06em] uppercase text-gray-700">Clowes</span>
            <span class="inline-flex items-center rounded-[8px] border border-gray-300 bg-white px-2.5 py-1.5 text-[0.62rem] font-semibold tracking-[0.06em] uppercase text-gray-700">ENGIE</span>
            <span class="inline-flex items-center rounded-[8px] border border-gray-300 bg-white px-2.5 py-1.5 text-[0.62rem] font-semibold tracking-[0.06em] uppercase text-gray-700">Winvic</span>
            <span class="inline-flex items-center rounded-[8px] border border-gray-300 bg-white px-2.5 py-1.5 text-[0.62rem] font-semibold tracking-[0.06em] uppercase text-gray-700">Galliford Try</span>
            <span class="inline-flex items-center rounded-[8px] border border-gray-300 bg-white px-2.5 py-1.5 text-[0.62rem] font-semibold tracking-[0.06em] uppercase text-gray-700">Bowmer + Kirkland</span>
            <span class="inline-flex items-center rounded-[8px] border border-gray-300 bg-white px-2.5 py-1.5 text-[0.62rem] font-semibold tracking-[0.06em] uppercase text-gray-700">Willmott Dixon</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CORE COMPETENCIES / SECTORS — with hover-reveal descriptions
  ============================================================ -->
  <section class="rd-section rd-section--surface px-6 lg:px-10">
    <div class="max-w-7xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-14" data-animate>
        <p class="rd-label mb-3">Core Competencies</p>
        <h2 class="text-5xl lg:text-[4.25rem] font-black text-gray-900 mb-4 leading-[0.98]">Expertise Across All Sectors</h2>
        <div class="w-12 h-1 bg-red-600 mx-auto"></div>
      </div>

      <!-- Sector grid — 2 columns -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Multi-Room Residential -->
        <div class="rd-sector-card group rounded-[15px] overflow-hidden" data-animate>
          <img
            src="/assets/reynolds/project-lisbon-st-leeds.jpg"
            alt="Multi-Room Residential drylining project"
            class="w-full h-80 object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="rd-sector-card-overlay rounded-[15px]"></div>
          <!-- Always-visible title -->
          <div class="rd-sector-card-content">
            <div class="flex items-center gap-2 mb-3">
              <svg class="w-6 h-6 text-red-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-black text-white mb-0 transition-all duration-300 group-hover:mb-3">Multi-Room Residential</h3>
            <!-- Description revealed on hover -->
            <p class="text-white/80 text-sm leading-relaxed mb-4 max-h-0 overflow-hidden opacity-0 group-hover:max-h-40 group-hover:opacity-100 transition-all duration-500 ease-out">
              High-density residential projects, including student accommodation and luxury apartments, delivering acoustic performance and superior finishes.
            </p>
            <a href="/services" class="rd-link-underline inline-flex items-center gap-2 text-white text-sm font-bold tracking-wider uppercase opacity-0 group-hover:opacity-100 transition-all duration-300 hover:text-red-400">
              Learn More
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Commercial Office Space -->
        <div class="rd-sector-card group rounded-[15px] overflow-hidden" data-animate data-delay="100">
          <img
            src="/assets/reynolds/drylining-01.jpg"
            alt="Commercial Office Space drylining project"
            class="w-full h-80 object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="rd-sector-card-overlay rounded-[15px]"></div>
          <div class="rd-sector-card-content">
            <div class="flex items-center gap-2 mb-3">
              <svg class="w-6 h-6 text-red-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-black text-white mb-0 transition-all duration-300 group-hover:mb-3">Commercial Office Space</h3>
            <p class="text-white/80 text-sm leading-relaxed mb-4 max-h-0 overflow-hidden opacity-0 group-hover:max-h-40 group-hover:opacity-100 transition-all duration-500 ease-out">
              Bespoke drylining and ceiling solutions for modern corporate environments, focusing on aesthetics and functionality.
            </p>
            <a href="/services" class="rd-link-underline inline-flex items-center gap-2 text-white text-sm font-bold tracking-wider uppercase opacity-0 group-hover:opacity-100 transition-all duration-300 hover:text-red-400">
              Learn More
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Industrial & Warehousing -->
        <div class="rd-sector-card group rounded-[15px] overflow-hidden" data-animate data-delay="200">
          <img
            src="/assets/reynolds/project-building.jpg"
            alt="Industrial and Warehousing drylining project"
            class="w-full h-80 object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="rd-sector-card-overlay rounded-[15px]"></div>
          <div class="rd-sector-card-content">
            <div class="flex items-center gap-2 mb-3">
              <svg class="w-6 h-6 text-red-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-black text-white mb-0 transition-all duration-300 group-hover:mb-3">Industrial &amp; Warehousing</h3>
            <p class="text-white/80 text-sm leading-relaxed mb-4 max-h-0 overflow-hidden opacity-0 group-hover:max-h-40 group-hover:opacity-100 transition-all duration-500 ease-out">
              Specialised fit-outs for large-scale warehouses incorporating multi-story office blocks with fire and acoustic requirements.
            </p>
            <a href="/services" class="rd-link-underline inline-flex items-center gap-2 text-white text-sm font-bold tracking-wider uppercase opacity-0 group-hover:opacity-100 transition-all duration-300 hover:text-red-400">
              Learn More
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Hotels & Leisure -->
        <div class="rd-sector-card group rounded-[15px] overflow-hidden" data-animate data-delay="300">
          <img
            src="/assets/reynolds/project-bletchley.jpg"
            alt="Hotels and Leisure drylining project"
            class="w-full h-80 object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="rd-sector-card-overlay rounded-[15px]"></div>
          <div class="rd-sector-card-content">
            <div class="flex items-center gap-2 mb-3">
              <svg class="w-6 h-6 text-red-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M7 13c1.66 0 3-1.34 3-3S8.66 7 7 7s-3 1.34-3 3 1.34 3 3 3zm12-6h-8v7H3V5H1v15h2v-3h18v3h2v-9c0-2.21-1.79-4-4-4z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-black text-white mb-0 transition-all duration-300 group-hover:mb-3">Hotels &amp; Leisure</h3>
            <p class="text-white/80 text-sm leading-relaxed mb-4 max-h-0 overflow-hidden opacity-0 group-hover:max-h-40 group-hover:opacity-100 transition-all duration-500 ease-out">
              Premium finishes for the hospitality sector, ensuring rapid deployment and durable, high-quality results.
            </p>
            <a href="/services" class="rd-link-underline inline-flex items-center gap-2 text-white text-sm font-bold tracking-wider uppercase opacity-0 group-hover:opacity-100 transition-all duration-300 hover:text-red-400">
              Learn More
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       PHOTO-BACKED STATS / COUNTERS
  ============================================================ -->
  <section class="rd-section relative px-6 lg:px-10 overflow-hidden">
    <img
      src="/assets/reynolds/home-stats-bg.png"
      alt="Reynolds Dryline team installing internal walls"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/55"></div>

    <div class="relative z-10 max-w-7xl mx-auto">
      <div class="text-center mb-10 lg:mb-12" data-animate>
        <p class="rd-label !text-white/80 mb-3">By The Numbers</p>
        <h2 class="text-5xl lg:text-6xl font-black text-white">Built on Proven Delivery</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6">
        <article class="bg-red-600/95 backdrop-blur-sm text-white p-8 rounded-[15px] border border-white/20 shadow-2xl shadow-black/30" data-animate>
          <img
            src="/assets/reynolds/stats-icon-studwall.png"
            alt="Stud wall icon"
            class="h-20 w-auto mb-5 object-contain"
            loading="lazy"
          />
          <p class="text-xs font-bold tracking-[0.2em] uppercase text-white/75 mb-4">Stud Wall Installed (sq ft)</p>
          <p class="text-4xl lg:text-5xl font-black leading-none mb-4">
            <span data-counter data-target="4800000" data-suffix="+">4,800,000+</span>
          </p>
          <p class="text-white/90 text-sm font-semibold tracking-wide uppercase">square feet of stud wall delivered</p>
          <p class="text-white/70 text-[0.68rem] tracking-[0.12em] uppercase mt-3">Since 1963 • Delivered to date</p>
        </article>

        <article class="bg-red-600/95 backdrop-blur-sm text-white p-8 rounded-[15px] border border-white/20 shadow-2xl shadow-black/30" data-animate data-delay="100">
          <img
            src="/assets/reynolds/stats-icon-buildings.png"
            alt="Buildings icon"
            class="h-20 w-auto mb-5 object-contain"
            loading="lazy"
          />
          <p class="text-xs font-bold tracking-[0.2em] uppercase text-white/75 mb-4">Buildings Completed</p>
          <p class="text-4xl lg:text-5xl font-black leading-none mb-4">
            <span data-counter data-target="350" data-suffix="+">350+</span>
          </p>
          <p class="text-white/90 text-sm font-semibold tracking-wide uppercase">buildings and schemes handed over</p>
          <p class="text-white/70 text-[0.68rem] tracking-[0.12em] uppercase mt-3">Since 1963 • Delivered to date</p>
        </article>

        <article class="bg-red-600/95 backdrop-blur-sm text-white p-8 rounded-[15px] border border-white/20 shadow-2xl shadow-black/30" data-animate data-delay="200">
          <img
            src="/assets/reynolds/stats-icon-revenue.png"
            alt="Revenue icon"
            class="h-20 w-auto mb-5 object-contain"
            loading="lazy"
          />
          <p class="text-xs font-bold tracking-[0.2em] uppercase text-white/75 mb-4">Project Value Delivered (£m)</p>
          <p class="text-4xl lg:text-5xl font-black leading-none mb-4">
            <span data-counter data-target="950" data-prefix="£" data-suffix="m+">£950m+</span>
          </p>
          <p class="text-white/90 text-sm font-semibold tracking-wide uppercase">construction value delivered</p>
          <p class="text-white/70 text-[0.68rem] tracking-[0.12em] uppercase mt-3">Since 1963 • Delivered to date</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       LATEST PROJECTS
  ============================================================ -->
  <section class="rd-section rd-section--dark px-6 lg:px-10">
    <div class="max-w-7xl mx-auto">
      <!-- Section header -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-12 gap-4" data-animate>
        <div>
          <p class="rd-label mb-3">Track Record</p>
          <h2 class="text-5xl lg:text-[4.1rem] font-black text-white leading-[0.98]">Latest Projects</h2>
        </div>
        <a href="/projects" class="rd-hero-cta rd-btn-outline whitespace-nowrap">
          View Projects
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Projects grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Bendigo Building -->
        <div class="rd-panel bg-white flex flex-col sm:flex-row overflow-hidden group" data-animate>
          <div class="sm:w-48 flex-shrink-0 overflow-hidden rounded-tl-[15px] rounded-tr-[15px] sm:rounded-tr-none sm:rounded-bl-[15px] border-b border-gray-200 sm:border-b-0 sm:border-r sm:border-gray-200">
            <img
              src="/assets/reynolds/project-28rs.jpg"
              alt="Bendigo Building, Nottingham"
              class="w-full h-48 sm:h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-6 flex flex-col justify-between">
            <div>
              <h3 class="text-xl font-black text-red-600 mb-4">Bendigo Building</h3>
              <ul class="space-y-2 text-sm text-gray-600">
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                  </svg>
                  Nottingham, UK
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                  </svg>
                  Contractor: Graham
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
                  </svg>
                  Value: £4.4m
                </li>
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/>
                  </svg>
                  Status: On Going
                </li>
              </ul>
            </div>
            <div class="flex flex-wrap gap-2 mt-4">
              <span class="rd-tag-light rounded-[5px]">Metal Stud Partitioning</span>
              <span class="rd-tag-light rounded-[5px]">Suspended Ceilings</span>
              <span class="rd-tag-light rounded-[5px]">SFS</span>
            </div>
          </div>
