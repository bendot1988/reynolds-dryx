<script is:inline>
  (function () {
    const counters = document.querySelectorAll('[data-counter]');
    if (!counters.length) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const numberFormatter = new Intl.NumberFormat('en-GB');
    const animationDurationMs = 1600;

    function easeOutStandard(progress) {
      return 1 - Math.pow(1 - progress, 4);
    }

    function renderCounter(el, value) {
      const prefix = el.getAttribute('data-prefix') || '';
      const suffix = el.getAttribute('data-suffix') || '';
      el.textContent = `${prefix}${numberFormatter.format(value)}${suffix}`;
    }

    function animateCounter(el) {
      const target = Number(el.getAttribute('data-target') || '0');
      if (!Number.isFinite(target) || target <= 0) {
        renderCounter(el, 0);
        return;
      }
      if (prefersReducedMotion) {
        renderCounter(el, target);
        return;
      }

      // Keep real values as static fallback, then animate once observed.
      renderCounter(el, 0);
      const start = performance.now();

      function tick(now) {
        const progress = Math.min((now - start) / animationDurationMs, 1);
        const eased = easeOutStandard(progress);
        renderCounter(el, Math.round(target * eased));

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      }

      requestAnimationFrame(tick);
    }

    if (typeof window.IntersectionObserver !== 'function') {
      counters.forEach((counter) => {
        const target = Number(counter.getAttribute('data-target') || '0');
        renderCounter(counter, Number.isFinite(target) && target > 0 ? target : 0);
      });
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        animateCounter(el);
        observer.unobserve(el);
      });
    }, { threshold: 0.45 });

    counters.forEach((counter) => observer.observe(counter));
  })();
</script>

<script is:inline>
  (function () {
    const heroVideo = document.getElementById('rd-hero-video');
    if (!(heroVideo instanceof HTMLVideoElement)) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const introOffsetSeconds = 10;
    if (prefersReducedMotion) {
      heroVideo.pause();
      return;
    }

    function seekToIntroOffset() {
      if (!Number.isFinite(heroVideo.duration) || heroVideo.duration <= introOffsetSeconds) return;
      if (heroVideo.currentTime < introOffsetSeconds) {
        heroVideo.currentTime = introOffsetSeconds;
      }
    }

    heroVideo.addEventListener('loadedmetadata', () => {
      seekToIntroOffset();
      const playPromise = heroVideo.play();
      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(() => {});
      }
    }, { once: true });

    heroVideo.addEventListener('timeupdate', seekToIntroOffset);

    if (heroVideo.readyState >= 1) {
      seekToIntroOffset();
    }
  })();
</script>

